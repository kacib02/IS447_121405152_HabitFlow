{
  "name": "habitflow",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.[jt]sx?$": [
        "babel-jest",
        {
          "configFile": "./babel.config.js"
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(jest-)?react-native|@react-native|@react-native-community|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|@testing-library|drizzle-orm)"
    ],
    "moduleNameMapper": {
      "expo/src/winter/runtime.native": "<rootDir>/__mocks__/expo-winter.js",
      "expo/src/winter/installGlobal": "<rootDir>/__mocks__/expo-winter.js",
      "^expo-sqlite$": "<rootDir>/__mocks__/expo-winter.js",
      "^react-native$": "<rootDir>/__mocks__/react-native.js"
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "@react-navigation/stack": "^7.8.10",
    "drizzle-orm": "^0.45.2",
    "expo": "~54.0.33",
    "expo-sqlite": "^55.0.15",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.4"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "^55.0.18",
    "drizzle-kit": "^0.31.10",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.16",
    "react-native-worklets": "^0.8.1",
    "react-native-worklets-core": "^1.6.3",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
